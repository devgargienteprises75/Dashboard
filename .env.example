# API Configuration - Example
# Copy this file and rename to .env.local or .env.production

# Development Mode (for Vite proxy)
VITE_DEV_MODE=true

# Production API Proxy URL (if using backend proxy)
VITE_API_PROXY_URL=https://yourdomain.com/api

# N8N Backend URL
VITE_N8N_URL=https://n8n-dashboard-workflow.onrender.com

# Proxy Server Settings (for backend proxy)
PORT=3001
N8N_URL=https://n8n-dashboard-workflow.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com
